<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Cüzdan Pro - Sky Blue</title>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;900&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Nunito', sans-serif; -webkit-tap-highlight-color: transparent; }
    body { background: #f0f7ff; color: #334e68; padding: 15px; padding-bottom: 120px; }
    
    .pos { color: #2d6a4f !important; font-weight: 900; } 
    .neg { color: #ba1200 !important; font-weight: 900; } 
    .amt-navy { color: #102a43 !important; font-weight: 900; } 
    .overdue-orange { color: #f97316 !important; font-weight: 900; } 
    .due-soon { color: #eab308 !important; font-weight: 900; }
    
    .card { background: #ffffff; border-radius: 24px; padding: 22px; border: 1px solid #d1e9ff; margin-bottom: 15px; text-align: center; box-shadow: 0 4px 12px rgba(180, 215, 255, 0.25); }
    .main-total-card { border: none; background: linear-gradient(135deg, #48bbfe, #1c65ff); color: white; }
    .main-total-card h1 { color: white !important; }
    
    .input-field { width: 100%; background: #ffffff; border-radius: 16px; padding: 16px; color: #102a43; border: 2px solid #d1e9ff; margin-bottom: 12px; font-size: 16px; outline: none; font-weight: 700; }
    .btn-save { background: #1c65ff; color: white; border: none; padding: 18px; border-radius: 20px; width: 100%; font-weight: 900; cursor: pointer; transition: 0.2s; }
    .btn-save:hover { transform: scale(0.98); opacity: 0.9; }
    
    .mini-input { flex: 1; background: #ffffff; border: 2px solid #d1e9ff; border-radius: 14px; padding: 12px; color: #102a43; font-size: 12px; font-weight: 800; outline: none; }
    .tx-row { display: flex; justify-content: space-between; align-items: center; padding: 18px; background: #ffffff; border-radius: 20px; margin-bottom: 10px; border: 1px solid #e1efff; transition: 0.2s; cursor: pointer; }
    .tx-row:hover { transform: scale(0.98); background: #f8fbff; }
    
    .nav-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #ffffff; display: flex; justify-content: space-around; padding: 12px; border-top: 2px solid #d1e9ff; z-index: 1000; }
    .hidden { display: none !important; }
    .status-badge { font-size: 9px; padding: 3px 8px; border-radius: 8px; background: #e1efff; color: #1c65ff; font-weight: 900; }
    .manage-item { display: flex; justify-content: space-between; padding: 14px; background: #f8fbff; border-radius: 14px; margin-bottom: 6px; border: 1px solid #d1e9ff; }
    label { display: block; font-size: 10px; font-weight: 900; color: #1c65ff; margin-bottom: 5px; margin-left: 5px; text-transform: uppercase; }
    .waiting-badge { display: inline-block; background: #fef3c7; color: #d97706; font-size: 10px; padding: 2px 8px; border-radius: 12px; margin-left: 8px; font-weight: 900; }
    .stat-box { background: rgba(255,255,255,0.15); border-radius: 12px; padding: 8px; margin-top: 10px; font-size: 11px; }
  </style>
</head>
<body>

<div id="home-view">
  <div class="card main-total-card">
    <div style="font-size:11px; opacity:0.9; font-weight:900">KASA (TOPLAM NAKİT)</div>
    <h1 id="global-balance" style="font-size:36px; margin:5px 0">0 ₺</h1>
    <div id="global-aud" style="font-weight:800; font-size:13px; opacity:0.9">≈ 0 AUD</div>
    <div class="stat-box" id="waiting-summary"></div>
  </div>

  <select id="main-person-filter" class="input-field" style="border-color: #48bbfe;" onchange="selectPerson(this.value)"></select>

  <div id="person-detail-area" class="hidden">
    <div style="display: flex; gap: 8px; margin-bottom: 10px;">
       <select id="month-filter" class="mini-input" onchange="renderHome()"></select>
       <select id="cat-search-filter" class="mini-input" onchange="renderHome()"></select>
    </div>
    <div style="display: flex; gap: 8px; align-items: center; margin-bottom: 15px;">
      <input type="text" id="search-input" placeholder="Açıklama ara..." class="mini-input" style="flex: 2;" oninput="renderHome()">
      <div style="min-width:100px; background:#f0f7ff; border:2px solid #48bbfe; border-radius:14px; padding:6px; text-align:center;">
        <div style="font-size:8px; font-weight:900; color:#1c65ff;">NET ÖZET</div>
        <div id="search-total-val" class="amt-navy" style="font-size:13px;">0 ₺</div>
      </div>
    </div>
    <div id="history-container"></div>
  </div>

  <button class="btn-save" style="background:#f0f7ff; color:#1c65ff; border:2px dashed #48bbfe; margin-top:20px" onclick="showView('settings')">⚙️ KİŞİ, KATEGORİ VE VERİ YÖNETİMİ</button>
</div>

<div id="settings-view" class="hidden">
  <h2 style="text-align:center; color:#1c65ff; margin:20px 0">Yönetim Paneli</h2>
  <div class="card"><label>KİŞİLER</label><div id="manage-people-list"></div><button class="btn-save" style="padding:10px; font-size:12px" onclick="addNewItem('person')">+ YENİ KİŞİ</button></div>
  <div class="card"><label>ALACAK TÜRLERİ</label><div id="manage-cats-income"></div><button class="btn-save" style="padding:10px; font-size:12px" onclick="addNewItem('category', 'income')">+ KATEGORİ EKLE</button></div>
  <div class="card"><label>BORÇ TÜRLERİ</label><div id="manage-cats-expense"></div><button class="btn-save" style="padding:10px; font-size:12px" onclick="addNewItem('category', 'expense')">+ KATEGORİ EKLE</button></div>

  <div class="card" style="border-style: dashed; background: #eef7ff;">
    <label>💾 VERİ YEDEKLEME</label>
    <div style="display: flex; gap: 10px; margin-top: 10px;">
      <button class="btn-save" style="background:#627d98; flex:1; font-size:11px; padding:12px;" onclick="exportJSON()">📥 YEDEKLE</button>
      <button class="btn-save" style="background:#627d98; flex:1; font-size:11px; padding:12px;" onclick="document.getElementById('import-file').click()">📤 YÜKLE</button>
    </div>
    <input type="file" id="import-file" class="hidden" onchange="importJSON(event)">
  </div>

  <button class="btn-save" style="background:#334e68" onclick="goHome()">GERİ DÖN</button>
</div>

<div id="add-view" class="hidden">
  <h2 style="text-align:center; color:#1c65ff; margin:20px 0">İşlem Ekle</h2>
  <label>TÜR</label><select id="f-type" class="input-field" onchange="updateFormCats()"><option value="income">ALACAK (+)</option><option value="expense">BORÇ (-)</option></select>
  <label>KİŞİ</label><select id="f-person" class="input-field"></select>
  <label>KATEGORİ</label><select id="f-category" class="input-field"></select>
  <div style="display: flex; gap: 10px;"><div style="flex: 1;"><label>TARİH</label><input type="date" id="f-date" class="input-field"></div><div style="flex: 1;"><label>VADE TARİHİ</label><input type="date" id="f-due-date" class="input-field"></div></div>
  <label>TUTAR (₺)</label><input type="number" id="f-amount" placeholder="0.00" class="input-field">
  <label>AÇIKLAMA</label><input type="text" id="f-note" placeholder="Not..." class="input-field">
  <button class="btn-save" onclick="addTx()">KAYDET</button>
  <button id="del-btn" class="hidden" onclick="deleteCurrent()" style="width:100%; background:#fff; color:#ba1200; border:2px solid #ba1200; padding:15px; border-radius:20px; margin-top:10px; font-weight:900;">SİL</button>
  <button onclick="goHome()" style="width:100%; background:none; border:none; color:#627d98; margin-top:15px; font-weight:900;">İPTAL</button>
</div>

<div class="nav-bar">
  <div onclick="goHome()" style="text-align:center; cursor:pointer"><div style="font-size:22px">🏠</div><div style="font-size:10px; font-weight:800; color:#1c65ff">ANA SAYFA</div></div>
  <div onclick="showView('add')" style="text-align:center; cursor:pointer"><div style="font-size:22px">➕</div><div style="font-size:10px; font-weight:800; color:#1c65ff">EKLE</div></div>
</div>

<script>
  let txs = JSON.parse(localStorage.getItem('txs_sky_final') || '[]');
  let config = JSON.parse(localStorage.getItem('cfg_sky_final') || '{"people":[], "categories":{"income":[], "expense":[]}}');
  const months = ["Ocak", "Şubat", "Mart", "Nisan", "Mayıs", "Haziran", "Temmuz", "Ağustos", "Eylül", "Ekim", "Kasım", "Aralık"];
  let activeTab = null, rate = 0.0318, editId = null;

  function init() { 
    if(config.people.length === 0) { config.people = ["Ali", "Ayşe", "Mehmet"]; }
    if(config.categories.income.length === 0) { config.categories.income = ["Maaş", "Kira Geliri", "Serbest İş"]; }
    if(config.categories.expense.length === 0) { config.categories.expense = ["Yemek", "Fatura", "Alışveriş", "Eğlence"]; }
    updateDropdowns(); 
    renderHome(); 
    renderSettings(); 
  }

  function updateDropdowns() {
    const mainP = document.getElementById('main-person-filter');
    const formP = document.getElementById('f-person');
    let pOpts = '<option value="">👤 Kişi Seçiniz...</option>';
    config.people.forEach(p => pOpts += `<option value="${p}">${p}</option>`);
    mainP.innerHTML = pOpts; 
    formP.innerHTML = pOpts; 
    updateFormCats();
  }

  function updateFormCats() {
    const type = document.getElementById('f-type').value;
    const catSelect = document.getElementById('f-category');
    let cOpts = ""; 
    (config.categories[type] || []).forEach(c => cOpts += `<option value="${c}">${c}</option>`);
    catSelect.innerHTML = cOpts || '<option value="">📂 Kategori Yok</option>';
  }

  function selectPerson(val) { activeTab = val; renderHome(); }

  function renderHome() {
    const mFilter = document.getElementById('month-filter')?.value || 'Hepsi';
    const cFilter = document.getElementById('cat-search-filter')?.value || 'all';
    const sInput = document.getElementById('search-input')?.value.toLowerCase() || '';
    const today = new Date().toISOString().split('T')[0];

    // Global bakiye
    const globalBal = txs.filter(t => !t.dueDate).reduce((acc, t) => t.type === 'income' ? acc + t.amount : acc - t.amount, 0);
    document.getElementById('global-balance').innerText = globalBal.toLocaleString('tr-TR') + " ₺";
    document.getElementById('global-aud').innerText = "≈ " + (globalBal * rate).toFixed(2) + " AUD";
    
    // Bekleyen alacak/borç özeti
    const waitingIncome = txs.filter(t => t.dueDate && t.type === 'income').reduce((sum, t) => sum + t.amount, 0);
    const waitingExpense = txs.filter(t => t.dueDate && t.type === 'expense').reduce((sum, t) => sum + t.amount, 0);
    document.getElementById('waiting-summary').innerHTML = `⏳ Bekleyen: <span style="color:#a7f3d0">+${waitingIncome.toLocaleString('tr-TR')}₺</span> / <span style="color:#fecaca">-${waitingExpense.toLocaleString('tr-TR')}₺</span>`;

    if (activeTab) {
      document.getElementById('person-detail-area').classList.remove('hidden');
      let pData = txs.filter(t => t.person === activeTab);
      
      let mOpts = '<option value="Hepsi">📅 Tüm Zamanlar</option>';
      [...new Set(pData.map(t => { const d = new Date(t.date); return `${months[d.getMonth()]} ${d.getFullYear()}`; }))].forEach(m => mOpts += `<option value="${m}">${m}</option>`);
      if(document.getElementById('month-filter').dataset.last !== mOpts) { document.getElementById('month-filter').innerHTML = mOpts; document.getElementById('month-filter').dataset.last = mOpts; }

      let cOpts = '<option value="all">📂 Tümü</option>';
      [...new Set(pData.map(t => t.category))].forEach(c => cOpts += `<option value="${c}">${c}</option>`);
      if(document.getElementById('cat-search-filter').dataset.last !== cOpts) { document.getElementById('cat-search-filter').innerHTML = cOpts; document.getElementById('cat-search-filter').dataset.last = cOpts; }

      let pFiltered = pData.filter(t => {
        const mStr = `${months[new Date(t.date).getMonth()]} ${new Date(t.date).getFullYear()}`;
        return (mFilter === "Hepsi" || mStr === mFilter) && (cFilter === "all" || t.category === cFilter) && (t.note || "").toLowerCase().includes(sInput);
      });

      const sTotal = pFiltered.filter(t => !t.dueDate).reduce((acc, t) => t.type === 'income' ? acc + t.amount : acc - t.amount, 0);
      document.getElementById('search-total-val').innerHTML = sTotal.toLocaleString('tr-TR') + " ₺";

      const container = document.getElementById('history-container');
      container.innerHTML = "";
      if(pFiltered.length === 0) { container.innerHTML = '<div class="card" style="padding:30px; text-align:center;">📭 Bu kriterlerde işlem bulunamadı.</div>'; return; }
      
      pFiltered.forEach(t => {
        const isWaiting = !!t.dueDate;
        const isOverdue = isWaiting && t.dueDate <= today;
        const isDueSoon = isWaiting && !isOverdue && (new Date(t.dueDate) - new Date(today)) / (1000*60*60*24) <= 3;
        let mainCol = t.type === 'income' ? 'pos' : 'neg';
        if(isOverdue) mainCol = 'overdue-orange';
        if(isDueSoon && !isOverdue) mainCol = 'due-soon';

        container.innerHTML += `<div class="tx-row" onclick="prepareEdit(${t.id})">
          <div style="text-align:left">
            <b class="${mainCol}">${t.note || 'İsimsiz'}</b> 
            ${isWaiting ? `<span class="status-badge">${isOverdue ? '⚠️ GECİKTİ' : (isDueSoon ? '🔔 YAKINDA' : '⏳ BEKLİYOR')}</span>` : ''}
            <br><small style="opacity:0.6">${t.category} • ${t.date}</small>
            ${isWaiting ? `<br><small class="${isOverdue ? 'overdue-orange' : (isDueSoon ? 'due-soon' : '')}">📅 Vade: ${t.dueDate}</small>` : ''}
          </div>
          <div class="${isOverdue ? 'overdue-orange' : (isDueSoon ? 'due-soon' : 'amt-navy')}"><b>${(t.type === 'income' ? '+' : '-') + t.amount.toLocaleString('tr-TR')}₺</b></div>
        </div>`;
      });
    } else { 
      document.getElementById('person-detail-area')?.classList.add('hidden'); 
    }
  }

  function addTx() {
    const amt = document.getElementById('f-amount').value;
    const pers = document.getElementById('f-person').value;
    if(!amt || !pers) return alert("❌ Kişi ve Tutar zorunludur!");
    if(parseFloat(amt) <= 0) return alert("❌ Tutar 0'dan büyük olmalı!");
    
    const data = { 
      id: editId || Date.now(), 
      type: document.getElementById('f-type').value, 
      person: pers, 
      category: document.getElementById('f-category').value, 
      date: document.getElementById('f-date').value || new Date().toISOString().split('T')[0], 
      dueDate: document.getElementById('f-due-date').value || null, 
      amount: parseFloat(amt), 
      note: document.getElementById('f-note').value || "İşlem" 
    };
    
    if(editId) txs = txs.map(t => t.id === editId ? data : t); 
    else txs.unshift(data);
    
    localStorage.setItem('txs_sky_final', JSON.stringify(txs)); 
    goHome();
  }

  function prepareEdit(id) {
    const t = txs.find(x => x.id === id); 
    if(!t) return;
    editId = id; 
    showView('add');
    document.getElementById('f-type').value = t.type; 
    updateFormCats();
    document.getElementById('f-person').value = t.person; 
    document.getElementById('f-category').value = t.category;
    document.getElementById('f-date').value = t.date; 
    document.getElementById('f-due-date').value = t.dueDate || "";
    document.getElementById('f-amount').value = t.amount; 
    document.getElementById('f-note').value = t.note;
    document.getElementById('del-btn').classList.remove('hidden');
  }

  function renderSettings() {
    const pList = document.getElementById('manage-people-list'); 
    if(!pList) return;
    pList.innerHTML = "";
    config.people.forEach((p, i) => pList.innerHTML += `<div class="manage-item"><span>👤 ${p}</span><button style="color:#ba1200; border:none; background:none; font-weight:900; cursor:pointer" onclick="removeItem('person', ${i})">🗑️ SİL</button></div>`);
    
    ['income', 'expense'].forEach(type => {
      const cList = document.getElementById('manage-cats-' + type); 
      if(!cList) return;
      cList.innerHTML = "";
      config.categories[type].forEach((c, i) => cList.innerHTML += `<div class="manage-item"><span>📁 ${c}</span><button style="color:#ba1200; border:none; background:none; font-weight:900; cursor:pointer" onclick="removeItem('category', ${i}, '${type}')">🗑️ SİL</button></div>`);
    });
  }

  function addNewItem(type, catType) { 
    const name = prompt("✨ İsim girin:"); 
    if(name && name.trim()) { 
      if(type === 'person') config.people.push(name.trim()); 
      else config.categories[catType].push(name.trim()); 
      saveCfg(); 
    } 
  }
  
  function removeItem(type, index, catType) { 
    if(confirm("⚠️ Bu öğeyi silmek istediğinize emin misiniz?")) { 
      if(type === 'person') config.people.splice(index, 1); 
      else config.categories[catType].splice(index, 1); 
      saveCfg(); 
    } 
  }
  
  function saveCfg() { 
    localStorage.setItem('cfg_sky_final', JSON.stringify(config)); 
    updateDropdowns(); 
    renderSettings(); 
    renderHome(); 
  }
  
  function showView(v) { 
    ['home', 'add', 'settings'].forEach(x => {
      const el = document.getElementById(x + '-view');
      if(el) el.classList.add('hidden');
    }); 
    const target = document.getElementById(v + '-view');
    if(target) target.classList.remove('hidden');
    if(v === 'home') { 
      editId = null; 
      const delBtn = document.getElementById('del-btn');
      if(delBtn) delBtn.classList.add('hidden'); 
    } 
  }
  
  function goHome() { 
    activeTab = null; 
    const filter = document.getElementById('main-person-filter');
    if(filter) filter.value = "";
    showView('home'); 
    renderHome(); 
  }
  
  function deleteCurrent() { 
    if(confirm("⚠️ Bu işlem kalıcı olarak silinecek. Devam etmek istiyor musunuz?")) { 
      txs = txs.filter(t => t.id !== editId); 
      localStorage.setItem('txs_sky_final', JSON.stringify(txs)); 
      goHome(); 
    } 
  }

  function exportJSON() {
    const data = { txs, config };
    const blob = new Blob([JSON.stringify(data, null, 2)], {type: "application/json"});
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; 
    a.download = `cuzdan_yedek_${new Date().toISOString().split('T')[0]}.json`; 
    a.click();
    URL.revokeObjectURL(url);
    alert("✅ Yedek başarıyla oluşturuldu!");
  }

  function importJSON(e) {
    const file = e.target.files[0];
    if(!file) return;
    const reader = new FileReader();
    reader.onload = (x) => {
      try {
        const data = JSON.parse(x.target.result);
        txs = data.txs || [];
        config = data.config || { people: [], categories: { income: [], expense: [] } };
        localStorage.setItem('txs_sky_final', JSON.stringify(txs));
        localStorage.setItem('cfg_sky_final', JSON.stringify(config));
        init(); 
        alert("✅ Veriler başarıyla yüklendi!");
        goHome();
      } catch(err) { 
        alert("❌ Hata: Dosya okunamadı! Geçerli bir yedek dosyası seçin."); 
      }
    };
    reader.readAsText(file);
    e.target.value = '';
  }
  
  init();
</script>
</body>
</html>
